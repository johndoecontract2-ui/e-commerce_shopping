# ─────────────────────────────────────────────────────────────
#  ShopCart — Server environment variables
#  Copy this file to `.env` and fill in real values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Database — use your own connection string (MongoDB Atlas or self-hosted)
MONGO_URI=mongodb://127.0.0.1:27017/shopcart

# Auth — generate long random strings, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=shopcart_token

# Payment gateway (Razorpay test keys — keep server-side only, never expose the secret)
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me

# Bcrypt / lockout policy
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_MINUTES=15
